{
  "name": "deepseek",
  "version": "1.0.0",
  "type": "provider",
  "description": "DeepSeek API provider",
  "default_base_url": "https://api.deepseek.com/v1",
  "api_mode": "chat_completions",
  "config_schema": [
    { "key": "api_key", "label": "API Key", "type": "secret", "required": false, "description": "Set via DEEPSEEK_API_KEY or LLM_API_KEY env var" },
    { "key": "default_model", "label": "Default Model", "type": "string", "default": "deepseek-v4-flash" }
  ],
  "env": {}
}
